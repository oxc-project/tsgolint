 	return os.Getenv(name)
 }
 
+func (s *osSys) PnpApi() *pnp.PnpApi {
+	return s.pnpApi
+}
+
 func newSystem() *osSys {
 	cwd, err := os.Getwd()
 	if err != nil {
@@ -66,11 +73,19 @@ func newSystem() *osSys {
 		os.Exit(int(tsc.ExitStatusInvalidProject_OutputsSkipped))
 	}
 
+	var fs vfs.FS = osvfs.FS()
+
