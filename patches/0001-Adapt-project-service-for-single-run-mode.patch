From 87b7b45b1dfacb191c11391ffa8187ec923d4607 Mon Sep 17 00:00:00 2001
From: Cameron Clark <cameron.clark@hey.com>
Date: Fri, 14 Nov 2025 11:09:52 +0000
Subject: [PATCH 1/5] Adapt project service for single run mode

---
 internal/project/project.go | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/internal/project/project.go b/internal/project/project.go
index 39c77aa78..01ec37142 100644
--- a/internal/project/project.go
+++ b/internal/project/project.go
@@ -3,6 +3,7 @@ package project
 import (
 	"context"
 	"fmt"
+	"runtime"
 	"slices"
 	"strings"
 	"sync"
@@ -358,7 +359,9 @@ func (p *Project) CreateProgram() CreateProgramResult {
 	// the same project never share a captured variable through a stale closure
 	// stored in the old program's options.
 	createCheckerPool := func(program *compiler.Program) compiler.CheckerPool {
-		return newCheckerPool(p.host.sessionOptions.CheckerPoolOptions, program, p.log)
+		opts := p.host.sessionOptions.CheckerPoolOptions
+		opts.MaxCheckers = runtime.GOMAXPROCS(0)
+		return newCheckerPool(opts, program, p.log)
 	}
 
 	// Create the command line, potentially augmented with typing files
