{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "definitions": {
    "no_object_comparison_class_option": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Class or interface name to restrict."
        },
        "forbidEqualityOperators": {
          "type": "boolean",
          "description": "Whether to also forbid equality operators for this class.",
          "default": false
        }
      }
    },
    "no_object_comparison_options": {
      "type": "object",
      "properties": {
        "classes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/no_object_comparison_class_option"
          },
          "description": "List of classes or interfaces to restrict from direct object comparison.",
          "default": []
        }
      }
    }
  }
}
